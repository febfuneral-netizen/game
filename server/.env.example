# ==================== 基础服务 ====================
PORT=3001
NODE_ENV=development

# ==================== 数据库 ====================
MONGO_URI=mongodb://localhost:27017/quiz-miniapp

# ==================== JWT 鉴权（生产环境务必更换为强随机字符串） ====================
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_EXPIRES_IN=7d

# ==================== 微信小程序 ====================
WX_APPID=your-wxapp-appid
WX_APP_SECRET=your-wxapp-secret

# ==================== CORS（生产环境改为你的域名，多个用逗号分隔） ====================
# CORS_ORIGIN=https://your-domain.com

# ==================== 排行榜 ====================
# LEADERBOARD_MAX_SIZE=50
# LEADERBOARD_CACHE_TTL=300

# ==================== 每日挑战 ====================
# DAILY_CHALLENGE_SUBJECTS=chinese,math,english,science,history,geography
# DAILY_CHALLENGE_REWARD=50

# ==================== 速率限制（接入 express-rate-limit 后启用） ====================
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100

# ==================== Redis（未来接入：排行榜缓存 / Session / 匹配） ====================
# REDIS_URL=redis://localhost:6379

# ==================== 实时匹配 ====================
# MATCHMAKING_TIMEOUT=30
# MATCHMAKING_POOL_SIZE=10
# MATCHMAKING_RANK_GAP=500
